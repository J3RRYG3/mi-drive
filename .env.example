# ─── GCP (Google Cloud Storage) ───────────────────────────────────────────────
# Obtener de: outputs de Terraform / Service Account JSON de GCP
GCP_PROJECT_ID=
GCP_CLIENT_EMAIL=
# La clave privada debe incluir saltos de línea como \n
GCP_PRIVATE_KEY=
GCP_BUCKET_NAME=

# ─── Azure SQL Database Serverless ────────────────────────────────────────────
# Obtener de: outputs de Terraform / Azure Portal → SQL Database
AZURE_SQL_SERVER=
AZURE_SQL_DATABASE=midrive-user-db
AZURE_SQL_USER=
AZURE_SQL_PASSWORD=

# ─── AWS Cognito (Autenticación) ──────────────────────────────────────────────
# Obtener de: outputs de Terraform / AWS Console → Cognito
AWS_REGION=
AWS_COGNITO_USER_POOL_ID=
AWS_COGNITO_CLIENT_ID=
