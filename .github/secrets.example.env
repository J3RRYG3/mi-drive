# ── Docker Hub ─────────────────────────────────────────────────────────────────
# hub.docker.com → Account Settings → Security → New Access Token
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=

# ── GCP — Google Cloud Platform ────────────────────────────────────────────────
# GCP_SERVICE_ACCOUNT_KEY se sube por separado desde .github/gcp-service-account.json
# (ver instrucciones en set-github-secrets.ps1)
GCP_PROJECT_ID=unir-481719
GCP_CLIENT_EMAIL=unir-exercise@unir-481719.iam.gserviceaccount.com
GCP_BUCKET_NAME=midrive-user-files-unir-481719
# Extraer el campo "private_key" del JSON del service account.
# Debe ser una sola línea con \n literales (no saltos de línea reales).
# Ejemplo: -----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n
GCP_PRIVATE_KEY=

# ── Azure SQL ──────────────────────────────────────────────────────────────────
AZURE_SQL_SERVER=midrive-sql-server.database.windows.net
AZURE_SQL_DATABASE=midrive-user-db
AZURE_SQL_USER=tfmadmin
AZURE_SQL_PASSWORD=
# Reemplazar AZURE_SQL_PASSWORD en la URL con el valor real
DATABASE_URL=sqlserver://midrive-sql-server.database.windows.net:1433;database=midrive-user-db;user=tfmadmin;password=REEMPLAZAR_CON_AZURE_SQL_PASSWORD;encrypt=true;trustServerCertificate=false;loginTimeout=30

# ── AWS Cognito ────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_COGNITO_USER_POOL_ID=us-east-1_it8f24kzt
AWS_COGNITO_CLIENT_ID=63nv35rl10ood945q2pelidp39
